DATA "%X",1234
DATA "%8D",1234
DATA "%8X",1234
DATA "%08D",1234
DATA "%-8D",1234
DATA "%+8D",1234
DATA "% 8D",1234
DATA "%F",1234.5678
DATA "%.2F",1234.5678
DATA "%6.2F",1234.5678
DATA ""

