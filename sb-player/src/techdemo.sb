@TESTSHIFT

DIM ARRAY3[6]

FOR I=0 TO LEN(ARRAY3)-1
 ARRAY3[I]=I
NEXT
A$="----------"
GOSUB @PRTDIM

A$="UNSHIFT A,99"
UNSHIFT ARRAY3,99
GOSUB @PRTDIM

A$="R=SHIFT(A)"
RET=SHIFT(ARRAY3)
GOSUB @PRTDIM

A$="PUSH A,99"
PUSH ARRAY3,99
GOSUB @PRTDIM

A$="R=POP(A)"
RET=POP(ARRAY3)
GOSUB @PRTDIM
RETURN

