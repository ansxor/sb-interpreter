WHILE 1
 READ A$
 IF A$=="" THEN BREAK
 READ B$

 PRINT "    INSTR(";
 PRINT CHR$(34);A$;CHR$(34);",";
 PRINT CHR$(34);B$;CHR$(34);
 PRINT ")";
 GOSUB @ARROW
