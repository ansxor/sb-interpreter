 PRINT CHR$(34);A$;CHR$(34);",";
 PRINT I;")";
 GOSUB @ARROW
 PRINT LEFT$(A$,I)
NEXT

A$="RIGHT$"
PY=10
GOSUB @BGPRTCTR
LOCATE 0,PY*2+2

FOR I=0 TO 5
 PRINT "     RIGHT$(";
 PRINT CHR$(34);A$;CHR$(34);",";
 PRINT I;")";

 GOSUB @ARROW

 PRINT RIGHT$(A$,I)
NEXT
RETURN

'--- SUBST
@TESTSUBST
A$="ABCDEFGHI"
