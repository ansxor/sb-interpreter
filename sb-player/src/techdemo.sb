'---SGN
@TESTSGN

LOCATE 0,5
FOR I=-10 TO 10
 PRINT "    SGN(";
 PRINT FORMAT$("%2D",I);
 PRINT ")";

 GOSUB @ARROW

 PRINT SGN(I)
NEXT

