'----- BG INIT MSG
@BGINITMSG

BGCLR 0
BGCLR 1
IF XMODE==0 THEN
 BGCLR 2
 BGCLR 3
ENDIF

MSG=0
BSX=0
BSY=0
BSZ=-128

IF XMODE==4 THEN
 GRW=320  'WIDTH
ELSE 
 GRW=400  'WIDTH
ENDIF

BGW=GRW/16   'WIDTH
BGH=GRH/16   'HEIGHT
BGSCREEN MSG,BGW,BGH
BGCLR MSG
BGOFS MSG,BSX,BSY,BSZ

IF XMODE==4 THEN RETURN
BGCLIP 0,0,0,GRW-1,BGH*16-1
BGCLIP 1,0,0,GRW-1,BGH*16-1

IF XMODE==0 THEN
 BGCLIP 2,0,0,GRW-1,BGH*16-1
 BGCLIP 3,0,0,GRW-1,BGH*16-1
ENDIF
RETURN

'--- GYROA
@TESTGYRO

SPMAX=3
GOSUB @SPINITMAX

FOR I=0 TO 2
 X1=200
 Y1=60+(60*I)
 W=25
 C=RGB(255,255,255)
 GLINE X1,Y1-W,X1,Y1+W,C
 GLINE X1-W,Y1,X1+W,Y1,C
 SPOFS I,X1,Y1,0
 SPSCALE I,2,2
NEXT

XON MOTION

PY=29
A$="B Button : EXIT"
GOSUB @TXTPRTCTR

WHILE 1
 LOCATE 0,5

 GYROA OUT Y, P, R
 SPROT 0, DEG(Y)
 SPROT 1, DEG(P)
 SPROT 2, DEG(R)

 LOCATE 3,(60+0)/8
 PRINT "YAW  =";FORMAT$("%4D",DEG(Y))
 LOCATE 3,(60+60)/8
 PRINT "PITCH=";FORMAT$("%4D",DEG(P))
 LOCATE 3,(60+120)/8
 PRINT "ROLL =";FORMAT$("%4D",DEG(R))

 BT=STKANDBTN()
 IF BT AND 32 THEN BREAK

 VSYNC 1
WEND

XOFF MOTION
CLS
RETURN

'--- ACCEL
@ACCEL

SPMAX=1
GOSUB @SPINITMAX

X1=200
Y1=120
W=100
C=RGB(255,255,255)
GLINE X1,Y1-W,X1,Y1+W,C
GLINE X1-W,Y1,X1+W,Y1,C
SPSCALE 0,3,3

XON MOTION

PY=29
A$="B Button : EXIT"
GOSUB @TXTPRTCTR

WHILE 1
 ACCEL OUT AX,AY,AZ

 LOCATE 0,5
 PRINT " ACCEL X=";FORMAT$("%06.3F",AX)
 PRINT " ACCEL Y=";FORMAT$("%06.3F",AY)
 PRINT " ACCEL Z=";FORMAT$("%06.3F",AZ)

 X1=200
 Y1=120
 X2=X1+(AX*100)
 Y2=Y1+(AY*100)
 SPOFS 0, X2,Y2

 BT=STKANDBTN()
 IF BT AND 32 THEN BREAK

 VSYNC 1
WEND
XOFF MOTION
CLS
RETURN

'--- MIC
@TESTMIC

XON MIC

LOCATE 0,5
PRINT "XON MIC"
PRINT "READY...";
WAIT 120
PRINT "START"

'0:8BIT
'1:16BIT
BIT=0
SEC=1

'0:8180HZ
'1:10190HZ
'2:16360HZ
'3:32730HZ
MODE=1

MICSTART MODE,BIT,SEC

FOR I=1 TO 60
 LOCATE 0,8
 PRINT FLOOR(100*I/60);"%"
' PRINT MICPOS
' PRINT MICSIZE
 VSYNC 1
NEXT
MICSTOP
SZ=MICSIZE

PRINT "STOP"
PRINT "MICSIZE=";SZ

DIM ARRAY4[SZ]
MICSAVE ARRAY4

XOFF MIC

FOR I=0 TO SZ-1
 X=400*I/SZ
 Y=120+(ARRAY4[I]-128)
 GPSET X,Y,RGB(0,255,0)
NEXT

RETURN

'--- EXPAD
@EXPAD
SPMAX=1
GOSUB @SPINITMAX

X1=200
Y1=120
W=100
C=RGB(255,255,255)
GLINE X1,Y1-W,X1,Y1+W,C
GLINE X1-W,Y1,X1+W,Y1,C
SPSCALE 0,3,3

XON EXPAD
IF RESULT==FALSE THEN RETURN

PY=29
A$="B Button : EXIT"
GOSUB @TXTPRTCTR

WHILE 1
 STICKEX OUT X,Y

 LOCATE 0,5,0
 PRINT " X=";
 PRINT FORMAT$("%06.3F",X)
 PRINT " Y=";
 PRINT FORMAT$("%06.3F",Y)

 X2=X1+X*100
 Y2=Y1-Y*100
 SPOFS 0,X2,Y2,-100

 BT=STKANDBTN()
 IF BT AND 32 THEN BREAK
 VSYNC 1
WEND

XOFF EXPAD

RETURN

'--- DIALOG
@TESTDLG

A$="Use DIALOG to display a dialog"
TYPE=RND(6)
' 0 = OK
' 1 = Yes/No
' 2 = Back/Next
' 3 = Cancel/Confirm
' 4 = Cancel/Run
' 5 = Next

LOCATE 0,6
PRINT "  DIALOG(";
PRINT CHR$(34);A$;CHR$(34);
PRINT ",";TYPE;")"

COLOR 7
PRINT ""
PRINT "   (The result is displayed on the Touch Screen)"

RET=DIALOG(A$,TYPE)

GOSUB @ARROW2
PRINT "  Return value = ";RET
'RET: -1:NO / 1:YES
RETURN

'----- MP TEST
@MPTEST
WAIT 1
CLS
LOCATE 0,2
PRINT " Test the local communication"
MPNUMIN=0
INPUT " How many systems to be used (2 or 4)?",MPNUMIN
IF MPNUMIN<2 || MPNUMIN>4 THEN GOTO @MPTEST
MPMAX=MPNUMIN  'PLAYERS
TAG$="COM"

LOCATE 0,4
PRINT "  MPSTART";
MPSTART MPMAX,TAG$
PRINT " RESULT:";RESULT;
IF RESULT==-1 THEN
 RETURN
ENDIF

PRINT " / MPLOCAL:";MPLOCAL;
IF MPHOST<0 THEN
 RETURN
ENDIF

PY=29
A$="B Button : EXIT"
GOSUB @TXTPRTCTR

WHILE 1
 IF MPLOCAL==0 THEN
  LOCATE 0,4
  ? " "*39
  LOCATE 0,4
  SNDMSG$=""
  INPUT " Enter any message:",SNDMSG$
  IF SNDMSG$=="" THEN SNDMSG$=" "
  MPSEND SNDMSG$
  BREAK
 ELSEIF MPLOCAL!=0 THEN
  MPRECV OUT MPSNDR,RCVMSG$
  IF MPSNDR!=-1 THEN
   LOCATE 0,4:? " "*39
   LOCATE 0,4:? " Received message:";RCVMSG$
   BREAK
  ENDIF
 ENDIF
WEND

WHILE 1
 COLOR 7
 LOCATE 0,5
 PRINT "  RESULT:";RESULT;" / MPLOCAL:";MPLOCAL;" / MPCOUNT:";MPCOUNT
 IF MPCOUNT<2 THEN
  BREAK
 ENDIF

 FOR ID=0 TO 3
  GOSUB @MPSUB
  VSYNC 1
 NEXT

 BT=STKANDBTN()
 IF BT AND 32 THEN BREAK
WEND

GOSUB @BSKIPOFF
MPEND

RETURN

'---
@MPSUB
X=0
Y=ID*6+6

COLOR 15
LOCATE X,Y+0
PRINT "[ID:";ID;"]";
PRINT "-"*44

IF ID>=MPCOUNT THEN RETURN

IF ID==MPLOCAL THEN
 COLOR 5
 PRINT "(YOU)";
ELSE
 COLOR 13
 PRINT "     ";
ENDIF

PRINT " / ";
IF ID==MPHOST THEN
 PRINT "Host system";
ELSE
 PRINT "Guest system ";
ENDIF

PRINT " / Name:";MPNAME$(ID);
PRINT " / MPSTAT:";MPSTAT(ID)

BT=BUTTON(0,ID)
PRINT " BUTTON:";HEX$(BT,4);

STICK ID OUT SX,SY
A$=FORMAT$("%6.3F",SX)
A$=A$+","
A$=A$+FORMAT$("%6.3F",SY)
PRINT "  / STICK:(";A$;")"

TOUCH ID OUT TS,TX,TY
A$=FORMAT$("%03D",TS)
A$=A$+":"
A$=A$+FORMAT$("%03D",TX)
A$=A$+","
A$=A$+FORMAT$("%03D",TY)
PRINT " TOUCH:(";A$;")"

PRINT " DATA:";
FOR J=0 TO 8
 RET=MPGET(ID,J)
 IF J>0 THEN PRINT ",";
 PRINT HEX$(RET,4);
NEXT

RETURN


'-------
@SPEEDTEST

LOCATE 0,6
PRINT "  Content         : Score(The faster, the greater)"
PRINT " -----------------:-------------------------------"

PRINT "  Addition        : ";
SCORE=0
CNT=MAINCNT
I=0
WHILE ((MAINCNT-CNT)<60)
 I=I+1
 SCORE=SCORE+1
WEND
PRINT SCORE

PRINT "  PRINT Statement : ";
X=CSRX
Y=CSRY
SCORE=0
CNT=MAINCNT
WHILE ((MAINCNT-CNT)<60)
 C=&H41-(SCORE MOD 26)
 LOCATE X,Y:PRINT CHR$(C)
 SCORE=SCORE+1
WEND
LOCATE X,Y
PRINT SCORE

PRINT "  Moving a sprite : ";
SPSET 0,2544
SCORE=0
CNT=MAINCNT
WHILE ((MAINCNT-CNT)<60)
 SPOFS 0,(SCORE MOD 400),120
 SCORE=SCORE+1
WEND
PRINT SCORE

PRINT "  Drawing a line  : ";
SCORE=0
CNT=MAINCNT
WHILE ((MAINCNT-CNT)<60)
 GLINE RND(400),RND(240),RND(400),RND(240),RGB(0,0,128)
 SCORE=SCORE+1
WEND
PRINT SCORE

RETURN
'-------
@DEMO1

XSCREEN 0,512,4

PY=28
PX=0
LOCATE PX,PY,-250
PRINT "+Control Pad : MOVE(Left or Right)"
PRINT"    B Button : EXIT"

FOR I=0 TO 240-1
 U=0
 V=I
 W=400
 H=1
 SPSET I,U,V,W,H,1
 SPHOME I,W/2,H
NEXT
L=32
ANG=0
WHILE 1
 BT=STKANDBTN()
 IF BT AND 32 THEN BREAK
 IF BTN AND 4 THEN L=L-1
 IF BTN AND 8 THEN L=L+1
 IF L<1   THEN L=1
 IF L>200 THEN L=200
 ANG=(ANG+1) MOD 360
 A=ANG
 FOR I=0 TO 240-1
  X=SIN(RAD(A))*L
  Y=I
  Z=-I
  SPOFS I,X+200,Y,Z
  SPSCALE I,(I/120),4
  SPROT I,ANG
  A=A+1
 NEXT
 VSYNC 1
WEND
CLS
XMODE=0
GOSUB @SCRNINIT
RETURN

'-------
@DEMO2
XSCREEN 0,512,2
GCLS:CLS:SPCLR:BGCLR
SPDEF
EFCON 'Effector ON
EFCSET 1
BGMPLAY 41
'---
GPRIO 1024
GLINE 0,240,400,0,RGB(64,64,64)
GPAINT 0,0,RGB(96,96,96)
GPAINT 399,239,RGB(160,160,160)
GLINE 0,0,400,240,RGB(64,64,64)
SX=40*4
SY=24*4
GFILL SX,SY,400-SX,240-SY,RGB(128,128,128)
GBOX  SX,SY,400-SX,240-SY,RGB(64,64,64)
'---
CMAX=5
DIM SPC[CMAX]
COPY SPC,"@CHRDATA"
@CHRDATA
DATA 1432,1435,1438,1441,1444
'---
HIS=40
ZMAX=1000+200
DIM HD[CMAX],TL[CMAX]
DIM SPX[CMAX],SPY[CMAX],SPZ[CMAX]
DIM VX[CMAX],VY[CMAX],VZ[CMAX]
DIM HX[CMAX,HIS],HY[CMAX,HIS],HZ[CMAX,HIS]
DIM STX[CMAX],STY[CMAX],STZ[CMAX]

PY=29
A$="B Button : EXIT"
PX=25-(LEN(A$)/2)
LOCATE PX,PY,-250
PRINT A$;
'---
IX=0
FOR CI=0 TO CMAX-1
 SPX[CI]=RND(400):STX[CI]=SPX[CI]
 SPY[CI]=RND(240):STY[CI]=SPY[CI]
 SPZ[CI]=RND(200):STZ[CI]=SPZ[CI]
 SPSET IX,SPC[CI]
 SPOFS IX,SPX[CI],SPY[CI],SPZ[CI]
 SPHOME IX,16,16
 IX=IX+1
 '
 SPSET IX,0
 SPCOLOR IX,RGB(255,255,255,255)
 IX=IX+1
 '
 FOR I=0 TO HIS-1
  SPSET IX,SPC[CI]
  SPHOME IX,16,16
  IX=IX+1
 NEXT
 HD[CI]=0:TL[CI]=0
 VX[CI]=0:VY[CI]=0:VZ[CI]=0
 '
NEXT
'---
M=510-IX
IF M>20 THEN M=20
FOR I=0 TO M-1
 SPSET IX,242
 OX=((RND(400) DIV 32)*32)+32
 OY=((RND(192) DIV 32)*32)+32
 OZ=RND(ZMAX)-200
 SPOFS IX,OX,OY,OZ
 SPHOME IX,8,8
 GOSUB @CALCSC
 SPSCALE IX,SC,SC
 C=128
 SPCOLOR IX,RGB(C,255,255,255)
 IX=IX+1
NEXT
'---

WHILE 1
 BT=STKANDBTN()
 IF BT AND 32 THEN BREAK

 FOR CI=0 TO CMAX-1

  IX=CI*(HIS+2)
  T=STX[CI]:P=SPX[CI]:V=VX[CI]
  GOSUB @GETVEC
  SPX[CI]=P+V:VX[CI]=V:X=SPX[CI]
  T=STY[CI]:P=SPY[CI]:V=VY[CI]
  GOSUB @GETVEC
  SPY[CI]=P+V:VY[CI]=V:Y=SPY[CI]
  Z=SPZ[CI]:V=STZ[CI]-Z
  IF V<-8 THEN V=-8
  IF V> 8 THEN V=8
  Z=Z+V
  IF Z<-256 THEN Z=-256
  IF Z>1000 THEN Z=1000
  SPZ[CI]=Z
 '
  SPOFS IX,X,Y,Z
  OZ=Z:GOSUB @CALCSC
  SPSCALE IX,SC,SC
  C=255
  SPCOLOR IX,RGB(C,255,255,255)
  IX=IX+1
 '---
  IF ABS(STX[CI]-X)<16 THEN
   IF ABS(STY[CI]-Y)<16 THEN
    IF ABS(STZ[CI]-Z)<32 THEN
     STX[CI]=RND(400)
     STY[CI]=RND(240)
     STZ[CI]=RND(ZMAX)-200
     SPCHR IX,RND(32)
     SPHOME IX,8,8
    ENDIF
   ENDIF
  ENDIF
 '---
  SPOFS IX,STX[CI],STY[CI],STZ[CI]
  SPROT IX,ANGLE
  ANGLE=(ANGLE+1) MOD 360
  OZ=STZ[CI]:GOSUB @CALCSC
  SPSCALE IX,SC,SC
  IX=IX+1
 '---
  H=HD[CI]
  T=TL[CI]
  HX[CI,H]=X
  HY[CI,H]=Y
  HZ[CI,H]=Z
  H=(H+1) MOD HIS
  HD[CI]=H
  FOR I=0 TO HIS-1
   N=(T+I) MOD HIS
   SPOFS IX,HX[CI,N],HY[CI,N],HZ[CI,N]
   C=(255/HIS)*I
   SPCOLOR IX,RGB(C,C,C,C)
   OZ=HZ[CI,N]:GOSUB @CALCSC
   SC=((1/HIS)*I)*SC
   SPSCALE IX,SC,SC
   IX=IX+1
  NEXT
  T=(T+1) MOD HIS
  TL[CI]=T
 '
 NEXT
 '---
 VSYNC 1
WEND
EFCOFF 'Effector OFF
BGMSTOP
CLS
XMODE=0
GOSUB @SCRNINIT
RETURN

'---
@CALCSC
SC=0.25+(4/ZMAX)*(ZMAX-(OZ+200))
RETURN
'---
@GETVEC
S=SGN(T-P):V=V+(S*1)
IF V<-4 THEN V=-4
IF V>4 THEN V=4
RETURN
'-------
@TXTPRTCTR
PX=((GRW/2)/8)-(LEN(A$)/2)
LOCATE PX,PY,0
PRINT A$;
RETURN
'-----
@BSKIPON
PX=25-(15/2)
PY=29
LOCATE PX,PY,-256
PRINT "B Button : SKIP";
RETURN
'--------
@BSKIPOFF
PX=25-(40/2)
PY=29
LOCATE PX,PY,-250
PRINT " "*40;
RETURN
'-------------SELECT MENU
@SELECT
LOGOSP=0
SPSET LOGOSP,4095
SPHIDE LOGOSP
SPOFS LOGOSP,348,16,-256
SPSHOW LOGOSP

CLS
BGCLR MSG

COLOR 7

PY=4

READ A$
PY=0
GOSUB @BGPRTCTR

IMAX=0
WHILE (1)
 READ A$,B$
 IF A$=="" THEN BREAK

 MENU$[IMAX]=A$
 SUBTI$[IMAX]=B$
 IMAX=IMAX+1
WEND

CX=0:CY=2
FOR I=0 TO IMAX-1
 PX=CX+1
 PY=CY+I
 A$=MENU$[I]
 GOSUB @BGPRT
 A$=SUBTI$[I]
 COLOR 13
 LOCATE 25,PY*2+1,128
 PRINT A$
NEXT

COLOR 15
PY=28
A$ = "+Control Pad : MOVE(Up or Down)"
PX=25-(LEN(A$)/2)
LOCATE PX,PY,0
PRINT A$

PY=29
LOCATE PX,PY,0
PRINT"    A Button : Confirm         ";

WHILE(1)
 PX=CX*2:PY=(CY+SEL)*2
 COLOR 7
 LOCATE PX+1,PY,128
 PRINT CHR$(58111)*23
 LOCATE PX+1,PY+1,128
 PRINT CHR$(58111)*23

 COLOR 15
 LOCATE PX+25,PY+1,-128
 PRINT SUBTI$[SEL]

 GOSUB @SWOFF
 GOSUB @SWON

 LOCATE PX+1,PY,800
 PRINT " "*23
 LOCATE PX+1,PY+1,800
 PRINT " "*23

 COLOR 13
 LOCATE PX+25,PY+1,128
 PRINT SUBTI$[SEL]

 IF BT AND 2+8 THEN SEL=SEL+1
 IF BT AND 1+4 THEN SEL=SEL-1
 IF SEL<0    THEN SEL=IMAX-1
 IF SEL>=IMAX THEN SEL=0
 IF BT AND 16 THEN BREAK
 IF BT AND 32 THEN SEL=-1:BREAK
WEND

BGCLR MSG
CLS
COLOR 15
SPHIDE LOGOSP
RETURN

'----------
@SWINIT
 BTBAK=0  'BACKUP(GLOBAL)
 BTCNT=0  'COUNT(GLOBAL)
RETURN

'---
DEF STKANDBTN()
' BTBAK=0  'BACKUP(GLOBAL)
' BTCNT=0  'COUNT(GLOBAL)
 SLV=0.2  'THRESHOLD
 BTN=BUTTON()
 STICK OUT SX,SY
 IF (SY>SLV)  THEN BTN=BTN OR 1
 IF (SY<-SLV) THEN BTN=BTN OR 2
 IF (SX<-SLV) THEN BTN=BTN OR 4
 IF (SX>SLV)  THEN BTN=BTN OR 8
 IF BTBAK!=BTN THEN BTCNT=0
 BTBAK=BTN
 BTCNT=BTCNT+1
 IF BTCNT==1 THEN RETURN BTN
 IF BTCNT>20 THEN BTCNT=BTCNT-3:RETURN BTN
 RETURN 0
END
'----------
@SWOFF
WHILE 1
 VSYNC 1
 IF STKANDBTN()==0 THEN BREAK
WEND

RETURN

'----------
@SWON
WHILE 1
 VSYNC 1
 BT=STKANDBTN()
 IF BT!=0 THEN BREAK
WEND
RETURN

'-------------HIT ANY BUTTON
@HITANYBTN
A$="PUSH ANY BUTTON"
PY=14
GOSUB @BGPRTCTR
VSYNC 20
GOSUB @SWOFF
GOSUB @SWON
A$="               "
PY=14
GOSUB @BGPRTCTR
RETURN

