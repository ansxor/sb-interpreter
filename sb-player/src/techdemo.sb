@TESTLEN

RESTORE @LENTABLE

FOR I=0 TO 99
 READ A$
 IF A$=="" THEN BREAK

 LOCATE 5,6+I*2
 PRINT "LEN(";
 PRINT CHR$(34);A$;CHR$(34);
 PRINT ")";
 LOCATE 30,6+I*2
 GOSUB @ARROW
 PRINT LEN(A$)
NEXT
RETURN

@LENTABLE
