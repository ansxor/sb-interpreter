'
' EXAMPLE8        
' Technical Demo  
'

XON 3DS

SELMAX=12
DIM MENU$[SELMAX]
DIM SUBTI$[SELMAX]

GOSUB @SWINIT

XMODE=0
GOSUB @SCRNINIT

'--- MAIN

MSEL=0
WHILE 1
 
 SEL=MSEL
 RESTORE @MENUMAIN
 GOSUB @SELECT
 IF SEL<0 THEN CONTINUE
 
 MSEL=SEL   'BACK UP
 
 ON SEL GOSUB @TESTCNSL,@TESTGRP,@TESTBG,@TESTSP,@TESTSND,@TESTSTR,@TESTCALC,@TESTTRY,@TESTFILE,@TESTPRG,@TESTOTHERS,@MINIDEMO
 
WEND

'--- CONSOLE
@TESTCNSL
WHILE 1
 
 RESTORE @MENUCNSL
 GOSUB @SELECT
 IF SEL<0 THEN BREAK
 
 A$=MENU$[SEL]
 IF A$=="EXIT" THEN BREAK
 PY=0
 GOSUB @BGPRTCTR
 
 ON SEL GOSUB @TESTXSCR2,@TESTXSCR4,@TESTCOLOR,@TESTLOCATE,@TESTATTR,@TESTSCROLL,@TESTFONTDEF,@TESTVISIBLE,@TESTWIDTH,@TESTFADE
 
 GOSUB @HITANYBTN
 GOSUB @SCRNINIT
 
WEND
RETURN

'--- SPRITE
@TESTSP
SEL=0
WHILE 1
 
 RESTORE @MENUSP
 GOSUB @SELECT
 IF SEL<0 THEN BREAK

 A$=MENU$[SEL]
 IF A$=="EXIT" THEN BREAK
 PY=0
 GOSUB @BGPRTCTR
 
 ON SEL GOSUB @TESTSPOFS,@TESTSPCLIP,@TESTSPROT,@TESTSPSCALE,@TESTSPCOLOR,@TESTSPCHR,@TESTSPANIM,@TESTSPCOL,@TESTSPLINK,@TESTSPUSED,@SPATTR
 
 GOSUB @HITANYBTN
 GOSUB @SCRNINIT
 
WEND
RETURN

'--- GRAPHICS
@TESTGRP
SEL=0
WHILE 1
 
 RESTORE @MENUGRP
 GOSUB @SELECT
 IF SEL<0 THEN BREAK
 
 A$=MENU$[SEL]
 IF A$=="EXIT" THEN BREAK
 PY=0
 GOSUB @BGPRTCTR
 
 ON SEL GOSUB @TESTGPAGE,@TESTGCLIP,@TESTRGB,@TESTCIRCLE,@TESTFILL,@TESTGTRI,@TESTGPUTCHR,@TESTPAINT,@TESTGCOPY,@TESTGPRIO,@TESTGSAVE
 
 GOSUB @HITANYBTN
 GOSUB @SCRNINIT
 
WEND
RETURN

'--- BG
@TESTBG
SEL=0
WHILE 1
 
 RESTORE @MENUBG
 GOSUB @SELECT
 IF SEL<0 THEN BREAK
 
 A$=MENU$[SEL]
 IF A$=="EXIT" THEN BREAK
 PY=0
 GOSUB @BGPRTCTR
 
 ON SEL GOSUB @TESTBGPUT,@TESTBGOFS,@TESTBGCLIP,@TESTBGCOLOR,@TESTBGROT,@TESTBGSCALE,@TESTBGANIM,@TESTBGSAVE,@TESTBGCRD
 
 GOSUB @HITANYBTN
 GOSUB @SCRNINIT
 
WEND
RETURN

'--- STRINGS
@TESTSTR
SEL=0
WHILE 1
 
 RESTORE @MENUSTR
 GOSUB @SELECT
 IF SEL<0 THEN BREAK
 
 A$=MENU$[SEL]
 IF A$=="EXIT" THEN BREAK
 PY=0
 GOSUB @BGPRTCTR
 
 ON SEL GOSUB @KANJI,@TESTCHR,@TESTVAL,@TESTHEX,@TESTFORMAT,@TESTLEN,@TESTINSTR,@TESTMID,@TESTSUBST
 
 GOSUB @HITANYBTN
 
WEND
RETURN

'--- CALC
@TESTCALC
SEL=0
WHILE 1
 
 RESTORE @MENUCALC
 GOSUB @SELECT
 IF SEL<0 THEN BREAK
 
 A$=MENU$[SEL]
 IF A$=="EXIT" THEN BREAK
 PY=0
 GOSUB @BGPRTCTR
 
 ON SEL GOSUB @TESTFLOOR,@TESTABS,@TESTSGN,@TESTMIN,@TESTRND,@TESTSQR,@TESTEXP,@TESTSORT,@TESTSHIFT
 
 GOSUB @HITANYBTN
 
WEND
RETURN

'--- FILE
@TESTFILE
SEL=0
WHILE 1
 
 RESTORE @MENUFILE
 GOSUB @SELECT
 IF SEL<0 THEN BREAK
 
 A$=MENU$[SEL]
 IF A$=="EXIT" THEN BREAK
 PY=0
 GOSUB @BGPRTCTR
 
 ON SEL GOSUB @TESTCHKF,@TESTFILES,@TESTFILES2,@TESTSAVE
 
 GOSUB @HITANYBTN
 
WEND
RETURN

'--- PROGRAM
@TESTPRG
SEL=0
WHILE 1
 
 RESTORE @MENUPRG
 GOSUB @SELECT
 IF SEL<0 THEN BREAK
 
 A$=MENU$[SEL]
 IF A$=="EXIT" THEN BREAK
 PY=0
 GOSUB @BGPRTCTR
 
 ON SEL GOSUB @TESTPGET,@TESTPSET,@TESTINS,@TESTDEL
 
 GOSUB @HITANYBTN
 
WEND
RETURN

'--- SIN/COS
@TESTTRY
SEL=0
WHILE 1
 
 RESTORE @MENUSIN
 GOSUB @SELECT
 IF SEL<0 THEN BREAK
 
 A$=MENU$[SEL]
 IF A$=="EXIT" THEN BREAK
 PY=0
 GOSUB @BGPRTCTR
 
 ON SEL GOSUB @TESTRAD,@TESTSIN,@TESTTAN,@TESTATAN,@TESTASIN,@TESTSINH
 
 GOSUB @HITANYBTN
 GOSUB @SCRNINIT
 
WEND
RETURN

'--- SOUND
@TESTSND
SEL=0
WHILE 1
 
 RESTORE @MENUSND
 GOSUB @SELECT
 IF SEL<0 THEN BREAK
 
 A$=MENU$[SEL]
 IF A$=="EXIT" THEN BREAK
 PY=0
 GOSUB @BGPRTCTR
 
 ON SEL GOSUB @TESTBEEP,@TESTBGMPLAY,@TESTWAVSET,@TESTBGMSET,@TESTBGMVOL,@TESTTALK,@TESTEFC,@TESTEFC2
 
 GOSUB @HITANYBTN
 GOSUB @SCRNINIT
 
WEND
RETURN

'--- OTHERS
@TESTOTHERS
SEL=0
WHILE 1
 
 RESTORE @MENUOTHERS
 GOSUB @SELECT
 IF SEL<0 THEN BREAK
 
 A$=MENU$[SEL]
 IF A$=="EXIT" THEN BREAK
 PY=0
 GOSUB @BGPRTCTR
 
 ON SEL GOSUB @TESTGYRO,@ACCEL,@EXPAD,@TESTMIC,@TESTDLG,@MPTEST,@SPEEDTEST,@TESTSYSTEM,@TESTCALLBK

 
 GOSUB @HITANYBTN
 GOSUB @SCRNINIT
 
WEND
RETURN

'--- MINI DEMO
@MINIDEMO
SEL=0
WHILE 1
 
 RESTORE @MENUDEMO
 GOSUB @SELECT
 IF SEL<0 THEN BREAK
 
 A$=MENU$[SEL]
 IF A$=="EXIT" THEN BREAK
 PY=0
 GOSUB @BGPRTCTR
 
 ON SEL GOSUB @DEMO1,@DEMO2,@DEMO3
 
' GOSUB @HITANYBTN
 GOSUB @SCRNINIT
 
WEND
RETURN

'--------------
'0 Upper Screen (3D) & Touch Screen not used
'1 Upper Screen (2D) & Touch Screen not used
'2 Upper Screen (3D) & Touch Screen used
'3 Upper Screen (2D) & Touch Screen used
'4 Upper Screen (2D) & Touch Screen combined
'
@TESTXSCR2

XMODE=2
GOSUB @SCRNINIT
GOSUB @BSKIPON

PY=1
A$="XSCREEN 2"
GOSUB @BGPRTCTR

PY=12
A$="3D MODE"
GOSUB @BGPRTCTR

DISP=0   'Upper Screen
SPMAX=64
GOSUB @SPINITMAX
GOSUB @BGDUMMY1
GOSUB @GRPINIT

FOR SPN=0 TO SPMAX-1
 X=RND(GRW)
 Y=RND(GRH)
 Z=RND(1024+256)-256

 U=RND(32)*16
 V=RND(14)*16+32
 W=16
 H=16
 SPCHR SPN,U,V,W,H

 SPOFS SPN,X,Y,Z
NEXT

DISP=1   'Touch Screen
SPMAX=64
GOSUB @SPINITMAX

GOSUB @SPINIT0
GOSUB @BGDUMMY1
GOSUB @GRPINIT

FOR SPN=0 TO SPMAX-1
 X=RND(GRW)
 Y=RND(GRH)
 Z=RND(1024+256)-256

 U=RND(32)*16
 V=RND(14)*16+32
 W=16
 H=16
 SPCHR SPN,U,V,W,H
 SPOFS SPN,X,Y,Z
NEXT

X=200
X2=160
Y=120
Y2=120
Z=0
FOR I=0 TO 800
 X=X+SGN(400-I)/2
 X2=X2-SGN(400-I)/2

 DISPLAY 0   'Upper Screen
 SCL=COS(RAD(I*2))+1   '0-2
 Z=1024-(SCL*1280/2)
 BGOFS BGN,X,Y,Z
 BGROT BGN,I MOD 360
 BGSCALE BGN,SCL,SCL

 GOSUB @PRTBGXYZ

 DISPLAY 1   'Touch Screen
 BGOFS BGN,X2,Y2,Z
 BGROT BGN,I MOD 360
 SCL=COS(RAD(I*2))+1
 BGSCALE BGN,SCL,SCL

 BT=STKANDBTN()
 IF BT AND 32 THEN BREAK

 VSYNC 1
NEXT

WAIT 60

XMODE=0
GOSUB @SCRNINIT

PY=1
A$="XSCREEN 0"
GOSUB @BGPRTCTR
CLS

RETURN

'---
@TESTXSCR4

XMODE=4
GOSUB @SCRNINIT
GOSUB @BSKIPON

PY=1
A$="XSCREEN 4"
GOSUB @BGPRTCTR

PY=12
A$="2D MODE"
GOSUB @BGPRTCTR

SPMAX=128
GOSUB @SPINITMAX
GOSUB @BGDUMMY1

FOR SPN=0 TO SPMAX-1
 X=RND(GRW)
 Y=RND(GRH)
 Z=RND(1024+256)-256

 U=RND(32)*16
 V=RND(14)*16+32
 W=16
 H=16
 SPCHR SPN,U,V,W,H
 SPOFS SPN,X,Y,Z
NEXT

X=160
Y=120
FOR I=0 TO 800
 BGROT BGN,I MOD 360
 SCL=COS(RAD(I*2))+1  '0-2
 Z=1024-(SCL*1280/2)
 Y=Y+SGN(400-I)
 BGOFS BGN,X,Y,Z
 BGSCALE BGN,SCL,SCL

 GOSUB @PRTBGXYZ
 BT=STKANDBTN()
 IF BT AND 32 THEN BREAK

 VSYNC 1
NEXT

WAIT 60

XMODE=0
GOSUB @SCRNINIT

PY=1
A$="XSCREEN 0"
GOSUB @BGPRTCTR
CLS

RETURN

'---
@PRTBGXYZ
LOCATE 0,10,-100
PRINT "  BG X=";FORMAT$("%4D",X)
PRINT "  BG Y=";FORMAT$("%4D",Y)
PRINT "  BG Z=";FORMAT$("%4D",Z)
RETURN

'---
@SCRNINIT
WIDTH 8
XSCREEN XMODE
VISIBLE 1,1,1,1
GPAGE 0,0
BGMSTOP

DISP=0
GOSUB @GRPINIT
GOSUB @BGINITMSG
RETURN
'------------

@BGDUMMY1
BGN=1

@BGDUMMY
IF XMODE==4 THEN
 BGW=320/16
 BGH=480/16
ELSE
 IF DISP==0 THEN
  BGW=400/16  'Upper Screen
 ELSE
  BGW=320/16  'Touch Screen
 ENDIF
 BGH=240/16
ENDIF

DISPLAY DISP
BGSCREEN BGN,BGW,BGH
BGHOME BGN,BGW*16/2,BGH*16/2
BGOFS BGN,BGW*16/2,BGH*16/2

FOR Y=0 TO BGH-1
 FOR X=0 TO BGW-1
  C=99+RND(3)
  BGPUT BGN,X,Y,C
 NEXT
NEXT

RETURN

'--- 
@TESTCOLOR
FOR I=0 TO 15
 COLOR 15
 LOCATE 5,I+5,0
 PRINT "COLOR ";FORMAT$("%2D",I);

 GOSUB @ARROW

 COLOR I
 PRINT "ABCDEFGHIJKLMNOPQRSTUVWXYZ"
NEXT

RETURN

'--- 
@TESTATTR

RESTORE @ATTRTABLE
I=0
LOCATE 0,6,0

WHILE 1
 READ ATR
 IF ATR<0 THEN BREAK
 ATTR 0
 PRINT "           ";
 PRINT "ATTR ";ATR;
 GOSUB @ARROW
 ATTR ATR
 PRINT "R"
 PRINT ""
 ATTR 0
WEND
RETURN

@ATTRTABLE
DATA 0  'TURN 0
DATA 1  'TURN 90
DATA 2  'TURN 180
DATA 3  'TURN 270
DATA 4  'FRIP H
DATA 8  'FRIP V
DATA -1

'--- 
@TESTSCROLL

RESTORE @SCRLTABLE

WHILE 1
 READ X1,Y1
 IF X1==0 AND Y1==0 THEN BREAK
 READ NUM

 A$="SCROLL "
 A$=A$+FORMAT$("%2D",X1)+","
 A$=A$+FORMAT$("%2D",Y1)
 PY=2
 GOSUB @BGPRTCTR

 FOR I=0 TO 500
  LOCATE RND(50),RND(30),0
  PRINT CHR$(&H41+RND(26));
 NEXT
 WAIT 30
 FOR I=1 TO NUM
  SCROLL X1,Y1
  VSYNC 3
  BT=STKANDBTN()
  IF BT AND 32 THEN BREAK
 NEXT
 IF BT AND 32 THEN BREAK
WEND
CLS
RETURN

@SCRLTABLE
DATA  0, 1,30
DATA  0,-1,30
DATA  1, 0,50
DATA -1, 0,50
DATA  0, 0,0

'---
@TESTFONTDEF

C=58090    'CHR CODE

RESTORE @FONTDATA

A$=""
FOR Y=0 TO 7
 READ D$
 FOR X=0 TO 7
  IF MID$(D$,X,1)!=" " THEN
   A$=A$+"FFFF"
  ELSE
   A$=A$+"0000"
  ENDIF
 NEXT
NEXT

LOCATE 0,5,0
PRINT "A$=";CHR$(34);A$;CHR$(34)
PRINT ""
PRINT "FONTDEF ";C;",A$"
FONTDEF C,A$

PRINT ""
PRINT "PRINT CHR$(";C;")";
GOSUB @ARROW
PRINT CHR$(C)
RETURN

@FONTDATA
DATA "        "
DATA " 1   1  "
DATA "        "
DATA "        "
DATA "1     1 "
DATA " 1   1  "
DATA "  111   "
DATA "        "

'--- LOCATE
@TESTLOCATE
FOR I=0 TO 20
 X=250/8
 Y=I+3
 Z=1024-(I*(1024+256)/20)

 LOCATE X-20,Y,Z
 COLOR 7
 PRINT "LOCATE ";
 PRINT FORMAT$("%2D",X);",";
 PRINT FORMAT$("%2D",Y);",";
 PRINT FORMAT$("%4D",Z);
 GOSUB @ARROW

 LOCATE X,Y,Z
 COLOR 15
 PRINT "A";
NEXT
RETURN

'--- VISIBLE
@TESTVISIBLE
SPN=0
SPSET SPN,0,144
SPSCALE SPN,3,3
SPHOME SPN,8,8
SPOFS SPN,200,120,-100

BGN=1
BGFILL BGN,3,4,400/16-4,240/16-4,99
BGOFS BGN,0,0,300

LOCATE 3,12,0
PRINT "ABCDEFGHIJKLMNOPQRSTUVWXYZ"

GOSUB @BSKIPON

RESTORE @VSBLDATA

WHILE 1

 READ P1,P2,P3,P4
 IF P1==-1 THEN BREAK

 LOCATE 0,4,0
 PRINT " VISIBLE ";
 PRINT P1;",";P2;",";P3;",";P4
 GOSUB @ARROW2

 VISIBLE P1,P2,P3,P4 'TEXT,GRP,BG,SP

 FOR I=1 TO 90
  BT=STKANDBTN()
  IF BT AND 32 THEN BREAK
  VSYNC 1
 NEXT
 IF BT AND 32 THEN BREAK
WEND
VISIBLE 1,1,1,1
GOSUB @BSKIPOFF

RETURN

@VSBLDATA
DATA 1,1,1,1
DATA 1,0,0,0
DATA 1,0,0,1
DATA 1,0,1,0
DATA 1,1,0,0
DATA 1,1,1,1
DATA -1,-1,-1,-1

'---
@TESTWIDTH
WIDTH 16
LOCATE 0,2
PRINT " WIDTH 16"
GOSUB @ARROW2
PRINT " Size of the console font has been set to 16-pixel."
PRINT " (Twice as large as height and width)"
GOSUB @HITANYBTN
WIDTH 8
LOCATE 0,4
PRINT " WIDTH 8"
GOSUB @ARROW2
PRINT " Size of the console font has been set to 8-pixel."
PRINT " (Standard size)"
RETURN

'---
@TESTFADE

SPMAX=64
GOSUB @SPINIT0
SPANIM SPN,"I",16,2263,8,2264,0
SPSCALE SPN,4,4
R=0
G=0
B=0
ALPHA=0
A1=1
WHILE 1
 FADE RGB(ALPHA,R,G,B)
 LOCATE 2,4
 PRINT "FADE RGB(";
 PRINT FORMAT$("%3D",ALPHA);",";
 PRINT R;",";G;",";B;")";
 ALPHA=ALPHA+A1
 IF ALPHA<=0   THEN A1=1
 IF ALPHA>=255 THEN A1=-1
 BT=STKANDBTN()
 IF BT THEN BREAK
 VSYNC 1
WEND
CLS
FADE RGB(0,R,G,B)
RETURN

'---
@KANJI
LOAD "PRG1:SYS/KANJITBL"
USE 1
RESTORE "1:@SB_KANJITBL"
FOR J=0 TO 4
 READ D$
 FOR I=0 TO LEN(D$)
  IF I>=25 THEN BREAK
  A$=MID$(D$,I,1)
  X=(J*10)+1
  Y=I+3
  LOCATE X,Y
  COLOR 13
  PRINT "&H";FORMAT$("%4X",ASC(A$));
  PRINT ":";
  COLOR 15
  PRINT A$;
 NEXT
NEXT
RETURN


'--- CHR$
@TESTCHR

FOR I=0 TO 255
 X=(I MOD 16)+30
 Y=FLOOR(I/16)+7
 Z=0
 LOCATE X,Y,Z
 PRINT CHR$(I)
NEXT

COLOR 13
FOR I=0 TO 15
 LOCATE 28-3,I+7,Z
 PRINT "&H";HEX$(I);"0:"

 LOCATE I+30,5,Z
 PRINT HEX$(I)
NEXT
COLOR 15

LOCATE 0,6,Z
RESTORE @CHRTABLE
WHILE 1
 READ X
 IF X<0 THEN BREAK
 PRINT "   ";
 PRINT "CHR$(&H";FORMAT$("%-4X",X);")";
 GOSUB @ARROW
 PRINT CHR$(X)
WEND
RETURN

@CHRTABLE
DATA 33
DATA 64
DATA 65
DATA 97
DATA 12354
DATA 12355
DATA 12356
DATA 12357
DATA 12450
DATA 12451
DATA 12452
DATA 12453
DATA 8657
DATA 8658
DATA 58007
DATA 58111
DATA 57860
DATA 57861
DATA -1

'--- GPAGE
@TESTGPAGE
RESTORE @GPAGETABLE 

WHILE 1
 READ X
 IF X<0 THEN BREAK

 PY=1
 A$=" "*20
 GOSUB @BGPRTCTR

 READ A$
 A$="PAGE "+STR$(X)+":"+A$
 GOSUB @BGPRTCTR

 GCLIP 0,0,16*2,399,239
 GPAGE X,X

 FOR I=1 TO 120
  BT=STKANDBTN()
  IF BT AND 32 THEN BREAK
  VSYNC 1
 NEXT
 IF BT AND 32 THEN BREAK
WEND
RETURN

@GPAGETABLE 
DATA 0,"DEFAULT PAGE"
DATA 4,"SPRITE DATA"
DATA 5,"BG DATA"
DATA 0,"DEFAULT PAGE"
DATA -1

'--- GCLIP
@TESTGCLIP
I=96
X1=(GRW/2)-I
X2=(GRW/2)+I
Y1=(GRH/2)-I
Y2=(GRH/2)+I
GCLIP 0,X1,Y1,X2,Y2

FOR I=1 TO 50
 GOSUB @RNDCOLOR
 X1=RND(240)
 Y1=RND(240)
 X2=RND(400)
 Y2=RND(240)
 GLINE X1,Y1,X2,Y2,C
NEXT

RETURN

'--- RGB
@TESTRGB
PY=2
A$="RGB(R,G,B)"
GOSUB @BGPRTCTR

FOR I=1 TO 8
 X=3
 Y=5+I
 Z=0
 GOSUB @RNDCOLOR
 LOCATE X,Y,Z
 PRINT "RGB(";
 PRINT FORMAT$("%3D",R);",";
 PRINT FORMAT$("%3D",G);",";
 PRINT FORMAT$("%3D",B);")";

 GOSUB @ARROW

 PRINT "&H";HEX$(C)
 GFILL 260,Y*8,360,Y*8+7,C
NEXT
RETURN

'-----------
@RNDCOLOR
R=RND(256)
G=RND(256)
B=RND(256)
C=RGB(R,G,B)
RETURN

'--- GCIRCLE
@TESTCIRCLE
PY=3
A$="Circle       Arc          Fan"
GOSUB @TXTPRTCTR

FOR I=1 TO 20
 GOSUB @RNDCOLOR
 X=RND(60)-30
 Y=RND(120)+70
 R=RND(30)+10
 A1=RND(360)
 A2=RND(360)
 GCIRCLE X+70 ,Y,R,C
 GCIRCLE X+200,Y,R,A1,A2,0,C
 GCIRCLE X+330,Y,R,A1,A2,1,C
NEXT
RETURN

'--- GFILL
@TESTFILL
PY=2
A$="GFILL    GBOX"
GOSUB @BGPRTCTR

FOR I=1 TO 50
 GOSUB @RNDCOLOR
 X1=RND(100)+50
 Y1=RND(150)+60
 X2=RND(100)+50
 Y2=RND(150)+60

 GFILL X1,Y1,X2,Y2,C
 GBOX X1+200,Y1,X2+200,Y2,C
NEXT
RETURN

'--- GTRI
@TESTGTRI
FOR I=1 TO 50
 GOSUB @RNDCOLOR
 X1=RND(300)+50
 Y1=RND(160)+40
 X2=RND(300)+50
 Y2=RND(160)+40
 X3=RND(300)+50
 Y3=RND(160)+40
 GTRI X1,Y1,X2,Y2,X3,Y3,C
NEXT
RETURN

'--- GPUTCHR
@TESTGPUTCHR
X=32
Y=16
FOR I=0 TO 6
 GOSUB @RNDCOLOR
 SCL=I+1
 GPUTCHR X,Y,"ABCDEFG",SCL,SCL,C
 Y=Y+(SCL*8)
NEXT
RETURN

'--- GPAINT
@TESTPAINT
GCLS

FOR I=1 TO 25
 GOSUB @RNDCOLOR
 X1=RND(360)+32
 Y1=RND(170)+48
 X2=RND(360)+32
 Y2=RND(170)+48
 GBOX X1,Y1,X2,Y2,C
NEXT

FOR I=1 TO 100
 GOSUB @RNDCOLOR
 X=RND(300)+48
 Y=RND(170)+48
 GPAINT X,Y,C
NEXT
RETURN

'--- GCOPY
@TESTGCOPY
X=20:Y=80
W=100:H=100
GOSUB @GRPRNDFILL

X1=X:Y1=Y:X2=X+W-1:Y2=Y+H-1
LOCATE X1/8,Y1/8-2
PRINT "Copy from"

WAIT 30

X3=150:Y3=Y1
GCOPY 0,X1, Y1, X2,Y2, X3, Y3, 0
LOCATE X3/8,Y3/8-2
PRINT "Copy to MODE 0"

X3=280:Y3=Y1
GCOPY 0,X1, Y1, X2,Y2, X3, Y3, 1
LOCATE X3/8,Y3/8-2
PRINT "Copy to MODE 1"

RETURN

'--- GFILL
@GRPRNDFILL
X1=X:Y1=Y
X2=X+W-1:Y2=Y+H-1
GFILL X1,Y1,X2,Y2,0

FOR I=0 TO 10
 GOSUB @RNDCOLOR
 X1=RND(W)+X
 Y1=RND(H)+Y
 X2=RND(W)+X
 Y2=RND(H)+Y
 GFILL X1,Y1,X2,Y2,C
NEXT

RETURN

'--- GSAVE
@TESTGSAVE

X=20:Y=80
W=100:H=100
GOSUB @GRPRNDFILL

DIM GBUFF[W*H]

PG=0  'G PAGE
FLAG=1  'Conversion disabled
'FLAG=0  'Conversion enabled
X=20
Y=80
W=100
H=100

'Save to array
GSAVE PG,X,Y,W,H,GBUFF,FLAG

GFILL 200,0,399,239,RGB(128,128,128)

FLAG=1  'TRUE:16bit-Physical color
'FLAG=0  'FALSE:32bit-Logical color
MODE=0 'FALSE:Does not copy transparent color
'MODE=1 'TRUE:Copies ths transparent color
X=250
GLOAD X,Y,W,H,GBUFF,FLAG,MODE

RETURN

'---
@TESTBGSAVE

GOSUB @BGDUMMY1

C=0
BGFILL BGN,13,0,BGW-1,BGH-1,C

X=0
Y=0
W=8
H=8

DIM BGBUFF[W*H]

BGSAVE BGN,X,Y,W,H,BGBUFF

WAIT 120
X=250/16
Y=3
BGLOAD BGN,X,Y,W,H,BGBUFF

RETURN

'--- GPRIO
@TESTGPRIO

SPMAX=21
GOSUB @SPINITMAX

LOCATE 0,4,-255
FOR I=0 TO SPMAX-1
 X=200
 Y=I*8+32
 Z=1024-(I*(1024+256)/20)
 IF Z>1023 THEN Z=1023
 SPOFS I,X,Y,Z
NEXT
LOCATE 0,3,-256
FOR I=0 TO SPMAX-1
 Z=1024-(I*(1024+256)/20)
 PRINT "    GPRIO ";Z
 GPRIO Z
 FOR J=1 TO 60
  BT=STKANDBTN()
  IF BT AND 32 THEN BREAK
  VSYNC 1
 NEXT
 IF BT AND 32 THEN BREAK
NEXT
WAIT 60
PRINT "    GPRIO 1024"
GPRIO 1024
RETURN

'---- SPRITE INIT
@SPINITMAX
FOR SPN=0 TO SPMAX-1
 GOSUB @SPINIT
NEXT
RETURN

@SPINIT0
SPN=0

@SPINIT
DISPLAY DISP
U=0
V=144
SPW=16
SPH=16

IF XMODE==4 THEN
 GRW=320   'WIDTH
 GRH=480   'HEIGHT
ELSE
 IF DISP==0 THEN
  GRW=400   'WIDTH
 ELSE
  GRW=320   'WIDTH
 ENDIF
 GRH=240   'HEIGHT
ENDIF

SPSET SPN,U,V,SPW,SPH
SPHOME SPN,SPW/2,SPH/2
SPOFS SPN,GRW/2,GRH/2,-100

RETURN

'---
@TESTBGPUT

GOSUB @BGDUMMY1
BGCLR BGN

C=96
FOR Y=0 TO 5
 FOR X=0 TO 11
  BGPUT BGN,X*2+1,Y*2+2,C
  LOCATE X*4+2,Y*4+6
  PRINT C
  C=C+1
 NEXT
NEXT

RETURN

'--------------
@TESTBGOFS

DIM BZ[4]
DIM BX[4]

FOR BGN=0 TO 3
 BGW = (400*2)/16
 BGH = 240/16
 BGSCREEN BGN,BGW,BGH
 BGHOME BGN,0,0
NEXT

FOR BGN=0 TO 3
 FOR X=0 TO BGW-1
  Y=11-(BGN*2)
  FOR I=Y TO 14
   C=609+(BGN MOD 2)*3
   IF I>Y THEN C=C+32
   BGPUT BGN,X,I,C
  NEXT
 NEXT

 MSG=BGN
 PY=BGN+1
 A$="BG LAYER "+STR$(BGN)
 GOSUB @BGPRTCTR
NEXT

GOSUB @BSKIPON

BX[0]=0
BX[1]=0
BX[2]=0
BX[3]=0

BZ[0]=-256
BZ[1]=-192
BZ[2]=0
BZ[3]=768

X1=0.5
FOR I=0 TO 10*60

 FOR BGN=0 TO 3
  X=BX[BGN]
  X=X+(4-BGN)*X1
  IF X>=400 OR X<=0 THEN X1=-X1
  BX[BGN]=X
  Y=0
  Z=BZ[BGN]
  BGOFS BGN,X,Y,Z
 NEXT

 BT=STKANDBTN()
 IF BT AND 32 THEN BREAK
 VSYNC 1
NEXT

MSG=0

FOR BGN=0 TO 3
 BGOFS BGN,0,0
NEXT
GOSUB @BSKIPOFF
RETURN

'--------------
@TESTBGCLIP
GOSUB @BGDUMMY1
I=96
X1=(BGW*16/2)-I
X2=(BGW*16/2)+I
Y1=(BGH*16/2)-I
Y2=(BGH*16/2)+I
BGCLIP BGN,X1,Y1,X2,Y2
X=200
Y=120
TM=120
BGANIM BGN,"XY",1,X,Y,-TM,X-200,Y,-TM,X,Y,0
RETURN

'--------------
@TESTBGCOLOR
GOSUB @BGDUMMY1
X=200
Y=120
Z=0
BGOFS BGN,X,Y,Z

R=255:G=0:B=0
LOCATE 2,4
PRINT "BGCOLOR ";
PRINT BGN;",";
PRINT "RGB(";R;",";G;",";B;")"
BGCOLOR BGN,RGB(R,G,B)
RETURN

'-------------
@TESTBGSCALE

GOSUB @BGDUMMY1
GOSUB @BSKIPON

X=200
Y=120
Z=0
BGOFS BGN,X,Y,Z

X=1
X1=-0.002

WHILE X<2
 X=X+X1
 IF X<0.2 THEN X1=-X1
 BGSCALE BGN,X,X

 PY=2
 A$="SCALE:"+FORMAT$("%.3F",X)
 GOSUB @BGPRTCTR

 BT=STKANDBTN()
 IF BT AND 32 THEN BREAK
 VSYNC 1
WEND

WAIT 15
GOSUB @BSKIPOFF

RETURN

'--- BGROT
@TESTBGROT

GOSUB @BGDUMMY1
GOSUB @BSKIPON

X=200
Y=120
Z=0
BGOFS BGN,X,Y,Z

FOR ANG=0 TO 360
 BGROT BGN, (ANG MOD 360)

 PY=2
 A$="ANGLE:"+STR$(ANG)+" DEG."
 GOSUB @BGPRTCTR

 BT=STKANDBTN()
 IF BT AND 32 THEN BREAK

 VSYNC 1
NEXT

WAIT 15
GOSUB @BSKIPOFF

RETURN

'--- BGANIM
@TESTBGANIM
GOSUB @BGDUMMY1
TM=120
X=200
Y=120
BGN=1
BGANIM BGN,"XY",TM,X,Y,-TM,400,240,-TM,X,Y,999

RETURN

'---
@TESTBGCRD
GOSUB @BSKIPON
GOSUB @BGDUMMY1
GOSUB @SPINIT0
SPCHR SPN,2564
SPSCALE SPN,2,2
FOR A=0 TO 600
 BGROT BGN,A         'Rotate BG
 TX=COS(RAD(A*2))*100+200  'Coordinates in BG
 TY=120
 BGCOORD BGN,TX,TY OUT X,Y 'Actual coordinates
 SPOFS SPN,X,Y       'Coordinates of a sprite
 SPROT SPN,A         'Rotate a sprite
 BT=STKANDBTN()
 IF BT AND 32 THEN BREAK
 VSYNC 1
NEXT
GOSUB @BSKIPOFF
RETURN

'--- SPOFS
@TESTSPOFS
SPMAX=21
GOSUB @SPINITMAX

FOR I=0 TO 20
 X=200
 Y=I*8+40-16
 Z=1024-(I*(1024+256)/20)

 SPOFS I,X,Y,Z

 LOCATE X/8-10,Y/8,Z
 COLOR 7
 PRINT "Z=";
 PRINT FORMAT$("%4D",Z);
 GOSUB @ARROW
NEXT
RETURN

'--- SPCLIP
@TESTSPCLIP

GOSUB @SPINIT0

I=96
X1=(GRW/2)-I
X2=(GRW/2)+I
Y1=(GRH/2)-I
Y2=(GRH/2)+I
SPCLIP X1,Y1,X2,Y2

SCL=2    'SCALE
SPSCALE SPN,SCL,SCL

TM=60    'TIME
X=200
Y=120
LPCNT=0
SPANIM SPN,"XY",TM,X,Y,-TM,X1,Y1,-TM,X2,Y2,-TM,X,Y,LPCNT

RETURN

'--- SPROT
@TESTSPROT

SPMAX=3
GOSUB @SPINITMAX

GOSUB @BSKIPON

FOR SPN=0 TO SPMAX-1

 X=SPN*120+80
 Y=120
 SPOFS SPN,X,Y
 GLINE X-32,Y,X+32,Y,RGB(255,255,0)
 GLINE X,Y-32,X,Y+32,RGB(255,255,0)

 Z=0
 SPHOME SPN,SPN*8,SPN*8
 LOCATE X/8-2,Y/8+5,Z
 PRINT "SPHOME"
 LOCATE X/8-2,Y/8+6,Z
 PRINT "X:";SPN*8
 LOCATE X/8-2,Y/8+7,Z
 PRINT "Y:";SPN*8

NEXT

FOR ANG=0 TO 360
 FOR SPN=0 TO SPMAX-1
  SCL=2
  SPSCALE SPN,SCL,SCL
  SPROT SPN,ANG
 NEXT

 PY=2
 A$="ANGLE:"+FORMAT$("%3D",ANG)+" DEG."
 GOSUB @BGPRTCTR

 BT=STKANDBTN()
 IF BT AND 32 THEN BREAK

 VSYNC 1
NEXT
GOSUB @BSKIPOFF

RETURN

'--- SPSCALE
@TESTSPSCALE

SPMAX=3
GOSUB @SPINITMAX

GOSUB @BSKIPON

FOR SPN=0 TO SPMAX-1

 X=SPN*120+80
 Y=120
 SPOFS SPN,X,Y
 GLINE X-32,Y,X+32,Y,RGB(255,255,0)
 GLINE X,Y-32,X,Y+32,RGB(255,255,0)

 Z=0
 SPHOME SPN,SPN*8,SPN*8
 LOCATE X/8-2,Y/8+5,Z
 PRINT "SPHOME"
 LOCATE X/8-2,Y/8+6,Z
 PRINT "X:";SPN*8
 LOCATE X/8-2,Y/8+7,Z
 PRINT "Y:";SPN*8

NEXT

SCL=1
X1=-0.004

WHILE SCL<3
 SCL = SCL+X1
 IF SCL<0.5 THEN X1=-X1

 FOR SPN=0 TO SPMAX-1
  SPSCALE SPN,SCL,SCL
 NEXT

 PY=2
 A$="SCALE:"+FORMAT$("%.3F",SCL)
 GOSUB @BGPRTCTR

 BT=STKANDBTN()
 IF BT AND 32 THEN BREAK

 VSYNC 1
WEND
GOSUB @BSKIPOFF

RETURN

'---
@SPCLRMAX
FOR SPN=0 TO SPMAX
 SPCLR SPN
NEXT
RETURN

'---
@TESTSPCOLOR

SPMAX=6
GOSUB @SPINITMAX

RESTORE @SPCOLORTABLE

FOR SPN=0 TO SPMAX-1
 READ ALPHA,R,G,B
 IF ALPHA<0 THEN BREAK

 IF ALPHA==255 THEN
  C=RGB(R,G,B)
 ELSE
  C=RGB(ALPHA,R,G,B)
 ENDIF

 X=100
 Y=SPN*32+40

 SCL=2   'SCALE
 SPOFS SPN,X,Y
 SPSCALE SPN,SCL,SCL
 SPCOLOR SPN,C

 LOCATE X/8+3,Y/8,0
 PRINT "RGB(";
 IF ALPHA!=255 THEN
  PRINT FORMAT$("%3D",ALPHA);",";
 ENDIF
 PRINT FORMAT$("%3D",R);",";
 PRINT FORMAT$("%3D",G);",";
 PRINT FORMAT$("%3D",B);")";
NEXT
RETURN

@SPCOLORTABLE
DATA 255,255,  0,  0
DATA 255,  0,255,  0
DATA 255,  0,  0,255
DATA  64,255,255,255
DATA 128,255,255,255
DATA 255,255,255,255
DATA -1,-1,-1,-1

RETURN

'---
@TESTSPCHR

SPMAX=6*3
GOSUB @SPINITMAX

FOR SPN=0 TO SPMAX-1
 SCL=2    'SCALE
 SPSCALE SPN,SCL,SCL
NEXT

FOR NUM=0 TO 2
 RESTORE @SPCHRTABLE

 FOR I=0 TO 5
  READ ATR
  IF ATR<0 THEN BREAK
  ATR=ATR OR 1  'VISIBLE

  SPN=(NUM*6)+I
  X=32+(I*64)
  Y=NUM*72+32
  U=0
  V=NUM*16+144

  Z=0
  SPOFS SPN,X,Y
  SPCHR SPN,U,V,SPW,SPH,ATR
  LOCATE X/8-3,Y/8+2,Z
  PRINT "U=";U
  LOCATE X/8-3,Y/8+3,Z
  PRINT "V=";V
  LOCATE X/8-3,Y/8+4,Z
  PRINT "ATTR=";ATR
  X=X+64
 NEXT
NEXT
RETURN

@SPCHRTABLE
DATA 0  'TURN0
DATA 2  'TURN90
DATA 4  'TURN180
DATA 6  'TURN270
DATA 8  'FRIP H
DATA 16 'FRIP V
DATA -1

'---
@TESTSPCOL

SPMAX=8
GOSUB @SPINITMAX

GOSUB @BSKIPON

FOR SPN=0 TO SPMAX-1
 SPCOL SPN,-SPW/2,-SPH/2,SPW,SPH,1
 X=SPN*32+64
 Y=120
 Z=0
 SPOFS SPN,X,Y
 SCL=2
 SPSCALE SPN,SCL,SCL
 IF SPN THEN LOCATE X/8,Y/8+2,Z:PRINT SPN
NEXT

ANG=0
SPN=0
FOR I=0 TO 15*60

 X=COS(RAD(ANG))*96+200
 Y=SIN(RAD(ANG*4))*48+120
 Z=0
 SPOFS SPN,X,Y,Z
 ANG=ANG+0.4
 IF ANG>=360 THEN ANG=ANG-360

 A$="SPHITSP:"
 A$=A$+FORMAT$("%3D",SPHITSP(SPN))

 PY=2
 GOSUB @BGPRTCTR

 BT=STKANDBTN()
 IF BT AND 32 THEN BREAK

 VSYNC 1
NEXT

CLS
RETURN

'---
@TESTSPANIM

SPMAX=4
GOSUB @SPINITMAX

SCL=2   'SCALE
FOR SPN=0 TO SPMAX-1
 SPSCALE SPN,SCL,SCL
NEXT

TM=120   'TIME
X=100
Y=48
Z=0
LPCNT=0    'LOOP COUNT
SPN=0
SPANIM SPN,"XY",TM,X,Y,TM,X+200,Y,LPCNT
LOCATE X/8,Y/8+2,Z
PRINT "XY not stored"

Y=Y+48
SPN=SPN+1
SPANIM SPN,"XY",TM,X,Y,-TM,X+200,Y,LPCNT
LOCATE X/8,Y/8+2,Z
PRINT "XY stored"

Y=Y+48
SPN=SPN+1
SPANIM SPN,"XY",TM,X,Y,-TM,X+200,Y,LPCNT
SPANIM SPN,"UV",8,U,V,8,U+16,V,8,U+32,V,LPCNT
LOCATE X/8,Y/8+2,Z
PRINT "XY stored + UV"

Y=Y+48
SPN=SPN+1
SPANIM SPN,"XY",TM,X,Y,-TM,X+200,Y,LPCNT
SPANIM SPN,"R",TM,0,-TM,360,LPCNT
SPANIM SPN,"UV",8,U,V,8,U+16,V,8,U+32,V,LPCNT
LOCATE X/8,Y/8+2,Z
PRINT "XY stored + UV+ R stored"

RETURN

'---
@TESTSPLINK

SPMAX=5
GOSUB @SPINITMAX

GOSUB @BSKIPON

FOR SPN=1 TO SPMAX-1
 X=0
 Y=16
 Z=0
 SPOFS SPN,X,Y,Z
NEXT

LOCATE 0,6,0
FOR SPN=1 TO SPMAX-1
 SPLINK SPN,SPN-1
 PRINT " SPLINK ";SPN;",";SPN-1
NEXT

FOR SPN=0 TO SPMAX-1
 FOR I=0 TO 360 STEP 4
  SPOFS SPN OUT X,Y
  X=X+COS(RAD(I))*3
  SPOFS SPN,X,Y

  LOCATE 0,SPN*2+15,0
  PRINT " SPOFS ";SPN;
  PRINT ",";
  PRINT FORMAT$("%3D",X);
  PRINT ",";
  PRINT FORMAT$("%3D",Y);

  BT=STKANDBTN()
  IF BT AND 32 THEN BREAK
  VSYNC 1
 NEXT
 IF BT AND 32 THEN BREAK
NEXT

GOSUB @BSKIPOFF

RETURN

'---
@TESTSPUSED
SPMAX=10
GOSUB @SPINITMAX
FOR I=0 TO SPMAX-1
 SPOFS I,200,I*16+40
 IF RND(2)==0 THEN SPCLR I
NEXT
FOR I=0 TO SPMAX-1
 LOCATE 8,I*2+5
 PRINT "SPUSED(";I;")";
 GOSUB @ARROW
 PRINT SPUSED(I)
NEXT
RETURN

'---
@SPATTR

SPMAX=8
GOSUB @SPINITMAX
GOSUB @BSKIPON
LOCATE 1,4
PRINT "Additive synthesis happens as setting a bit 5 of attribute to 1"

FOR SPN=0 TO SPMAX-1
 X=SPN*32+64
 Y=120
 Z=0
 SPOFS SPN,X,Y
 SCL=2
 SPSCALE SPN,SCL,SCL
 IF SPN>0 THEN SPCHR SPN,RND(1500)+2048
 SPCHR SPN OUT W,H,U,V,ATR
 ATR=ATR OR (1<<5)
 SPCHR SPN,W,H,U,V,ATR
NEXT

ANG=0
SPN=0
FOR I=0 TO 15*60
 X=COS(RAD(ANG))*96+200
 Y=SIN(RAD(ANG*4))*48+120
 Z=0
 SPOFS SPN,X,Y,Z
 ANG=ANG+0.4
 IF ANG>=360 THEN ANG=ANG-360

' A$="SPHITSP:"
' A$=A$+FORMAT$("%3D",SPHITSP(SPN))
' PY=2
' GOSUB @BGPRTCTR

 BT=STKANDBTN()
 IF BT AND 32 THEN BREAK
 VSYNC 1
NEXT
CLS
RETURN
'---

@TESTCALLBK
GOSUB @SPINIT0
TM=15
SPSCALE SPN,2,2
SPANIM SPN,"I",TM,2292,TM,2293,0
SPFUNC SPN,@SUBCALLBACK
WAIT 60*1.5
LOCATE 0,4
PRINT " CALL SPRITE"
CALL SPRITE
RETURN

'--- CALLBACK
@SUBCALLBACK
SPN=CALLIDX
PRINT " CALLIDX:";SPN
SPOFS SPN OUT X1,Y1
SPCLR SPN
FOR I=0 TO 7
 SPN=I
 X2=X1+COS(RAD(I*45))*400
 Y2=Y1+SIN(RAD(I*45))*400
 SPSET SPN,3394
 SPSCALE SPN,2,2
 SPANIM SPN,"XY",1,X1,Y1,-120,X2,Y2,1
NEXT
RETURN

'--- VAL
@TESTVAL
RESTORE @VALTABLE
LOCATE 0,6,0
WHILE 1
 READ A$
 IF A$=="" THEN BREAK

 PRINT "    ";
 PRINT "VAL(";CHR$(34);A$;CHR$(34);")";
 GOSUB @ARROW
 PRINT VAL(A$)
WEND
RETURN

@VALTABLE
