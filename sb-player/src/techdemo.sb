@GRPINIT
DISPLAY DISP
GPRIO 1024  '
GCLS

IF XMODE==4 THEN
 GRW=320   'WIDTH
 GRH=480   'HEIGHT
ELSE
 IF DISP==0 THEN
  GRW=400   'WIDTH
 ELSE
  GRW=320   'WIDTH
 ENDIF
 GRH=240   'HEIGHT
ENDIF

FOR I=0 TO GRW-1 STEP 8
 C=128
 IF (I MOD 16) THEN C=C/2
 GLINE I,0,I,GRH-1,RGB(0,0,C)
NEXT
FOR I=0 TO GRH-1 STEP 8
 C=128
 IF (I MOD 16) THEN C=C/2
 GLINE 0,I,GRW-1,I,RGB(0,0,C)
NEXT
RETURN

