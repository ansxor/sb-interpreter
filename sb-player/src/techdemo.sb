'--- BG PRINT SUB
@BGPRTCTR
PX=((GRW/2)/16)-(LEN(A$)/2)
@BGPRT
FOR IDX=0 TO LEN(A$)-1
 C=ASC(MID$(A$,IDX,1))
 IF C<0 THEN C=0
 IF C>=32*3 THEN C=0
 BGPUT MSG,PX+IDX,PY,C
NEXT
RETURN

'-------------
@TESTBEEP

GOSUB @BSKIPON

'TONE=0   'TONE NO. PRESET 0-133
'PITCH=0  '-32768 to 32767
'VOL=127  '0-127
'PAN=0    '0:LEFT/64:CENTER/127:RIGHT
'BEEP TONE,PITCH,VOL,PAN

LOCATE 0,6,0
PRINT "    Play SFX randomly in range from 0 thru 133
PRINT ""
FOR J=0 TO 10
 TONE = RND(134)   'TONE NUMBER

 PRINT "     BEEP ";TONE
 BEEP TONE

 FOR I=1 TO 60
  BT=STKANDBTN()
  IF BT AND 32 THEN BREAK
  VSYNC 1
 NEXT
 IF BT AND 32 THEN BREAK

NEXT
GOSUB @BSKIPOFF

RETURN

'--- BGMPLAY
@TESTBGMPLAY
TRK=0  'TRACK NUM. 0-7
NUM=RND(43)  'BGM NO. PRESET 0-42 / USER 128-255
MML$=""

LOCATE 0,6,0
PRINT "    Play BGMs randomly in range from 0 thru 42
PRINT ""
PRINT "    BGMPLAY ";NUM
BGMPLAY NUM

PRINT "    "
PRINT "    BGMSTOP is executed when an any button is pressed"
PRINT "    "
GOSUB @HITANYBTN
'--- BGMSTOP
PRINT "    BGMSTOP "
BGMSTOP
RETURN

'---
@TESTWAVSET
TONE=224  'TONE NO. 224、E55
A=40 'ATTACK 0-127
D=40 'DECAY 0-127
S=80 'SUSTAIN 0-127
R=60 'RELEASE 0-127

WAV$=""
FOR I=1 TO 64
 V=SIN(RAD(I*360/16))*120
 WAV$=WAV$+RIGHT$("00"+HEX$(V),2)

 X=240+I*2
 Y=120
 GLINE X,Y,X,Y-V,RGB(0,255,0)
NEXT
GLINE 240,Y,X,Y,RGB(255,0,0)
WAVSET TONE,A,D,S,R,WAV$

LOCATE 0,8,0
PRINT "TONE NUMBER:";TONE
PRINT ""
PRINT "ATTACK :";A
PRINT "DECAY  :";D
PRINT "SUSTAIN:";S
PRINT "RELEASE:";R
X=16
Y=120
C=RGB(255,255,0)
W=50
GLINE X,Y,X+A,Y-120,C
GLINE X+A,Y-120,X+A+D,Y-S,C
GLINE X+A+D,Y-S,X+A+D+W,Y-S,C
GLINE X+A+D+W,Y-S,X+A+D+W+R,Y,C
GLINE X,Y,X+A+D+W+R,Y,RGB(255,0,0)

LOCATE 0,20
PRINT " WAVSET ";
PRINT TONE;",";A;",";D;",";S;",";R;",";
PRINT CHR$(34);WAV$;CHR$(34)

MML$="@"+STR$(TONE)+"O4CDEFGABO5C"
BGMPLAY MML$
PRINT ""
PRINT " BGMPLAY ";CHR$(34);MML$;CHR$(34);

RETURN

'--- BGMSET
@TESTBGMSET

NUM=128  'BGM NO. 128-255
MML$="O4CDEFGABO5C"

LOCATE 0,6,0
PRINT " BGMSET ";
PRINT NUM;",";CHR$(34);MML$;CHR$(34)
BGMSET NUM,MML$

PRINT ""
NUM=128
PRINT " BGMPLAY ";NUM
BGMPLAY NUM

RETURN

'--- BGMVOL
@TESTBGMVOL

GOSUB @BSKIPON
BGMPLAY 1

FOR I=0 TO 8
 VOL=127-((8-I)*16)
 IF VOL<0 THEN VOL=0
 PY=3+I
 A$="BGMVOL "+STR$(VOL)
 GOSUB @BGPRTCTR
 BGMVOL VOL

 FOR J=1 TO 90
  BT=STKANDBTN()
  IF BT AND 32 THEN BREAK
  VSYNC 1
 NEXT
 IF J<=90 THEN BREAK
NEXT
BGMSTOP
GOSUB @BSKIPOFF
RETURN

'--- TALK
@TESTTALK

SPD=RND(65537)
PITCH=RND(65537)
A$=""
A$=A$+"<S"+STR$(SPD)+">"
A$=A$+"<P"+STR$(PITCH)+">"
A$=A$+"アカサタチEハぅヤラワ"
TALK A$
LOCATE 5,6,0
PRINT "TALK ";
PRINT CHR$(34);A$;CHR$(34)

RETURN

'--- EFCSET
@TESTEFC
LOCATE 0,6,0
COLOR 7
PRINT " Set the effector"
MML$="@1O4CDEFGABO5C"

EFCON 'Effector ON
TYPE=0 'Effector preset settings
COLOR 7
PRINT " (1) Play BGM without using the effector"
PRINT ""
COLOR 15
PRINT " EFCSET ";TYPE
EFCSET TYPE
'Effector preset settings
'0 = None
'1 = Reverb (BATHROOM)
'2 = Reverb (CAVE)
'3 = Reverb (SPACE)
BGMPLAY MML$
GOSUB @BGMWAIT
PRINT ""


TYPE=RND(3)+1 'Effector preset settings
COLOR 7
PRINT " (2) Play BGM using preset effector settings"
PRINT ""
COLOR 15
PRINT " EFCSET ";TYPE
EFCSET TYPE
BGMPLAY MML$
GOSUB @BGMWAIT
PRINT ""


T1=RND(2001) 'Initial reflection time (0-2000 MSEC)
T2=RND(2001) 'Reverberation sound delay time (0-2000 MSEC)
T3=RND(10000)+1 'Reverberation sound decay time (1-2000 MSEC)
F1=RND(11)/10 'Reverberation sound filter coefficient 1 (0.0-1.0)
F2=RND(11)/10 'Reverberation sound filter coefficient 2 (0.0-1.0)
G1=RND(11)/10 'Initial reflection sound gain (0.0-1.0)
G2=RND(11)/10 'Reverberation sound gain (0.0-1.0)

COLOR 7
PRINT " (3) Play BGM using advanced effector settings"
PRINT " (Effector parameters are specified randomly)"
PRINT "  Initial reflection time       :";T1;" MSEC"
PRINT "  Reverberation sound delay time  :";T2;" MSEC"
PRINT "  Reverberation sound decay time  :";T3;" MSEC"
PRINT "  Reverberation sound filter coefficient 1:";F1
PRINT "  Reverberation sound filter coefficient 2:";F2
PRINT "  Initial reflection sound gain     :";G1
PRINT "  Reverberation sound gain       :";G2
PRINT ""
COLOR 15

EFCSET T1,T2,T3,F1,F2,G1,G2
PRINT " EFCSET ";T1;",";T2;",";T3;",";F1;",";F2;",";G1;",";G2
BGMPLAY MML$
GOSUB @BGMWAIT
PRINT ""
EFCOFF 'Effector OFF
RETURN

'--- EFCWET
@TESTEFC2
LOCATE 0,6,0
COLOR 7
PRINT " Chaining the amount of effected (wet) sounds"
PRINT ""
MML$="@1O4CDEFGABO5C"

EFCON 'Effector ON
TYPE=1 'Effector preset settings
EFCSET TYPE

FOR I=0 TO 128 STEP 32
 W=I
 IF W>127 THEN W=127

 COLOR 15
 PRINT " EFCWET ";W;",";W;",";W
 EFCWET W,W,W
'BEEP wet value 0-127
'BGM wet value 0-127
'TALK wet value 0-127 (The effector is set to ON when 64 or greater is specified)

 BGMPLAY MML$
 GOSUB @BGMWAIT
 BEEP 6
 WAIT 30
 TALK "アイウエオ"
 WHILE TALKCHK()==TRUE
 WEND
 PRINT ""
NEXT
EFCOFF 'Effector OFF
RETURN
'---
@BGMWAIT
WHILE BGMCHK()==TRUE
 VSYNC 1
WEND
RETURN

