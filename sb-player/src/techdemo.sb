DATA "123456"
DATA "&H12"
DATA "&HFF"
DATA "ABC"
DATA "ア"
DATA ""

'--- HEX$
@TESTHEX
LOCATE 0,4
FOR I=-1 TO 20
 PRINT "        ";
 PRINT "HEX$(";FORMAT$("%2D",I);")";
 GOSUB @ARROW
 PRINT HEX$(I)
NEXT
RETURN

'--- FORMAT$
@TESTFORMAT

RESTORE @FORMATTABLE

FOR I=0 TO 99
 READ A$
 IF A$=="" THEN BREAK
 READ NUM

 Y=4+I*2
 LOCATE 4,Y
 PRINT "FORMAT$(";
 PRINT CHR$(34);A$;CHR$(34);
 PRINT ",";NUM;")";

 LOCATE 30,Y
 GOSUB @ARROW
 PRINT FORMAT$(A$,NUM)
NEXT
RETURN

@FORMATTABLE
