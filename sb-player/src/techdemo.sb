'---LEFT$/RIGHT$/MID$
@TESTMID

LOCATE 0,2
A$="ABCDE"
NUM=3
FOR I=0 TO 5
 PRINT "     MID$(";
 PRINT CHR$(34);A$;CHR$(34);",";
 PRINT I;",";NUM;")";

 GOSUB @ARROW

 PRINT MID$(A$,I,NUM)
NEXT

A$="LEFT$"
PY=5
GOSUB @BGPRTCTR
LOCATE 0,PY*2+2

FOR I=0 TO 5
