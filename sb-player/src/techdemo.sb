 READ I
 IF I<0 THEN BREAK
 READ NUM
 READ B$

 PRINT "  SUBST$(";
 PRINT CHR$(34);A$;CHR$(34);
 PRINT ",";I;",";NUM;",";
 PRINT CHR$(34);B$;CHR$(34);
