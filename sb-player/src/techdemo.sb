'---MIN
@TESTMIN

NUM=16
DIM ARRAY[NUM]

LOCATE 0,6
FOR I=0 TO NUM-1
 X=RND(1000)
 PRINT "    ARRAY[";
 PRINT FORMAT$("%2D",I);
 PRINT "] = ";
 PRINT FORMAT$("%3D",X)
 ARRAY[I]=X
NEXT

PRINT ""
PRINT "    MIN(ARRAY)";

GOSUB @ARROW

PRINT MIN(ARRAY)
PRINT ""
PRINT "    MAX(ARRAY)";

GOSUB @ARROW

PRINT MAX(ARRAY)

RETURN

'--- SORT/RSORT
@TESTSORT

NUM=16
DIM ARRAY2[NUM]

A$="        SORT    RSORT"
PY=2
GOSUB @BGPRTCTR

FOR I=0 TO NUM-1
 LOCATE 4,I+6
 X=RND(1000)
 PRINT "A[";
 PRINT FORMAT$("%2D",I);
 PRINT "] = ";
 PRINT FORMAT$("%3D",X)
 ARRAY2[I]=X
NEXT

SORT ARRAY2

FOR I=0 TO NUM-1
 LOCATE 20,I+6
 PRINT "A[";
 PRINT FORMAT$("%2D",I);
 PRINT "] : ";
 PRINT FORMAT$("%3D",ARRAY2[I])
NEXT

RSORT ARRAY2

FOR I=0 TO NUM-1
 LOCATE 35,I+6
 X=RND(1000)
 PRINT "A[";
 PRINT FORMAT$("%2D",I);
 PRINT "] : ";
 PRINT FORMAT$("%3D",ARRAY2[I])
NEXT

RETURN

'--- RND/RNDF
@TESTRND
A$="RND      RNDF"
PY=2
GOSUB @BGPRTCTR

LOCATE 0,6
NUM=16
FOR I=0 TO NUM-1
 PRINT "     RND(1000)";

 GOSUB @ARROW

 PRINT FORMAT$("%3D",RND(1000));
 PRINT "     RNDF()";

 GOSUB @ARROW

 PRINT FORMAT$("%.8F",RNDF())
NEXT

RETURN

'--- SQR/POW
@TESTSQR
A$="SQR       POW"
PY=2
GOSUB @BGPRTCTR

LOCATE 0,6
FOR I=1 TO 10
 PRINT "    ";
 PRINT "SQR(";
 PRINT FORMAT$("%2D",I);
 PRINT ")";

 GOSUB @ARROW

 T=SQR(I)
 PRINT FORMAT$("%.8F",T);
 PRINT "   ";

 PRINT "POW(";
 PRINT FORMAT$("%.8F",T);
 PRINT ",2)";

 GOSUB @ARROW

 PRINT POW(T,2)
NEXT

RETURN

'--- EXP/LOG
@TESTEXP
A$="EXP     LOG"
PY=2
GOSUB @BGPRTCTR

LOCATE 0,6
FOR I=0 TO 2
 PRINT "   ";
 PRINT "EXP(";
 PRINT FORMAT$("%1D",I);
 PRINT ")";

 GOSUB @ARROW

 T=EXP(I)
 PRINT FORMAT$("%.8F",T);
 PRINT "    ";

 PRINT "LOG(";
 PRINT FORMAT$("%.8F",T);
 PRINT ")";

 GOSUB @ARROW

 PRINT LOG(T)
NEXT
'Napier's Number E
RETURN

'--- RAD/DEG
@TESTRAD
A$="RAD    DEG"
PY=2
GOSUB @BGPRTCTR

LOCATE 0,6
FOR I=0 TO 360 STEP 30
 PRINT "  ";
 PRINT "RAD(";
 PRINT FORMAT$("%3D",I);")";

 GOSUB @ARROW

 T=RAD(I)
 PRINT FORMAT$("%1.8F",T);
 PRINT "    ";

 PRINT "DEG(";
 PRINT FORMAT$("%1.8F",T);
 PRINT ")";

 GOSUB @ARROW

 PRINT DEG(T)
NEXT
RETURN

'--- SIN/COS
@TESTSIN
SPMAX=72
GOSUB @SPINITMAX

GOSUB @BSKIPON

FOR SPN=0 TO SPMAX-1
 U=0
 V=144
 SPCHR SPN,U,V,SPW,SPH
NEXT

SPD=0.5
R=60

FOR ISO=0 TO 360 STEP SPD
 BT=STKANDBTN()
 IF BT AND 32 THEN BREAK

 Y1=0

 FOR SPN=0 TO SPMAX-1
  ANG=(SPN*5)+ISO
  IF SPN MOD 2 THEN ANG=ANG+180

  ANG=ANG MOD 360
  T=RAD(ANG)
  X=COS(T)*R+200
  Y=SIN(T)*(R/5)+32
  Z=POW((SIN(T)+1)*16,2)-256

  SPOFS SPN,X,Y+Y1,Z
  Y1=Y1+2.5
 NEXT
 VSYNC 1
NEXT
CLS
RETURN

'--- TAN
@TESTTAN
CX=GRW/2
CY=GRH/2
C=RGB(255,255,255)

FOR X=-90 TO 90 STEP 30

 GLINE (X*1.6)+CX,CY-8,(X*1.6)+CX,CY+8,C
 LOCATE X/5+25,15-1:PRINT X

NEXT
FOR Y=-3 TO 3
 GLINE CX-8,CY-Y*32,CX+8,CY-Y*32,C
 LOCATE 25+1,15-Y*4:PRINT Y
NEXT

GLINE 0,CY,399,CY,C
GLINE CX,0,CX,239,C

FOR X=-89 TO 89 STEP 0.1
 Y=TAN(RAD(X))
 GPSET CX+X*1.6,CY-Y*32,RGB(0,0,255)
NEXT

COLOR 9
LOCATE 25+9,15-4:PRINT "Y=TAN(RAD(X))"
RETURN

'--- ATAN
@TESTATAN

SPMAX=2
GOSUB @SPINITMAX

SPN=0
X1=200
Y1=64
SPOFS SPN,X1,Y1

SPN=1
X2=200
Y2=160
FOR X2=100 TO 300
 ANG=DEG(ATAN(Y2-Y1,X2-X1))
 IF ANG<0 THEN ANG=ANG+360

 LOCATE 0,19
 PRINT "  X1:";
 PRINT FORMAT$("%3D",X1)
 PRINT "  Y1:";
 PRINT FORMAT$("%3D",Y1)
 PRINT "  X2:";
 PRINT FORMAT$("%3D",X2)
 PRINT "  Y2:";
 PRINT FORMAT$("%3D",Y2)
 PRINT ""
 PRINT "  DEG(ATAN(Y2-Y1,X2-X1))";

 GOSUB @ARROW

 PRINT FORMAT$("%3.8F",ANG);

 SPOFS SPN,X2,Y2

 PY=2
 A$="ANGLE:"+FORMAT$("%3D",ANG)+" DEG."
 GOSUB @BGPRTCTR

 VSYNC 1
NEXT
R=300
GLINE X1,Y1,X1+R,Y1,RGB(255,255,0)
X3=X1+COS(RAD(ANG))*R
Y3=Y1+SIN(RAD(ANG))*R
GLINE X1,Y1,X3,Y3,RGB(255,255,0)

RETURN

'--- ASIN/ACOS
@TESTASIN
CX=GRW/2
CY=GRH/2
C=RGB(255,255,255)

FOR X=-1 TO 1
 GLINE X*80+CX,CY-8,X*80+CX,CY+8,C
 LOCATE X*10+25,15-1:PRINT X
NEXT
FOR Y=-3 TO 3
 GLINE CX-8,CY-Y*32,CX+8,CY-Y*32,C
 LOCATE 25+1,15-Y*4:PRINT Y
NEXT

GLINE 0,CY,399,CY,C
GLINE CX,0,CX,239,C

FOR X=-1 TO 1 STEP 0.01
 Y=ASIN(X)
 GPSET CX+X*80,CY-Y*32,RGB(255,0,0)

 Y=ACOS(X)
 GPSET CX+X*80,CY-Y*32,RGB(0,255,0)
NEXT

COLOR 3
LOCATE 25+9,15-9:PRINT "Y=ASIN(X)"
COLOR 5
LOCATE 25-9,15-9:PRINT "Y=ACOS(X)"

RETURN

'--- SINH/COSH
@TESTSINH
CX=GRW/2
CY=GRH/2
C=RGB(255,255,255)

FOR X=-2 TO 2
 GLINE X*32+CX,CY-8,X*32+CX,CY+8,C
 LOCATE X*4+25,15-1:PRINT X
NEXT
FOR Y=-3 TO 3
 GLINE CX-8,CY-Y*32,CX+8,CY-Y*32,C
 LOCATE 25+1,15-Y*4:PRINT Y
NEXT

GLINE 0,CY,399,CY,C
GLINE CX,0,CX,239,C

FOR X=-2 TO 2 STEP 0.01
 Y=SINH(X)
 GPSET CX+X*32,CY-Y*32,RGB(255,0,0)

 Y=COSH(X)
 GPSET CX+X*32,CY-Y*32,RGB(0,255,0)

 Y=TANH(X)
 GPSET CX+X*32,CY-Y*32,RGB(0,0,255)
NEXT

COLOR 3
LOCATE 25+9,15-9:PRINT "Y=SINH(X)"
COLOR 5
LOCATE 25-4,15-9:PRINT "Y=COSH(X)"
COLOR 9
LOCATE 25+9,15-4:PRINT "Y=TANH(X)"

RETURN

