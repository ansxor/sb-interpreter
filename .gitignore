# --- Rust ---
/target
**/*.rs.bk
# Cargo.lock IS committed (this workspace ships binaries -> reproducible builds).

# --- 3DS ROM images + extracted/derived code (copyrighted; never commit) ---
*.cia
*.cxi
*_code.bin
*.dec.bin

# --- Disassembly artifacts (regenerable from ROM; see sb-disassembly/README.md) ---
# Kept locally for development, but never published.
/sb-disassembly/

# --- Extracted sbsave corpus (~765MB; regenerable: python3 tools/extract_sbsave.py) ---
# The committed INDEX.json manifest is the reference; the unpacked tree is not.
harness/corpus/sbsave/files/
/sbsave/

# --- Source PDFs (copyrighted; text is extracted into sb-docs/) ---
*.pdf

# --- External reference checkout (clone separately; see README) ---
/osb

# --- Python ---
__pycache__/
*.pyc

# --- OS / editor ---
.DS_Store

# Oracle harvest capture scratch (resumable OUTFILEs/casefiles; regenerable)
harness/harvest/out/

# --- Ralph loop state (run notes / STOP / DONE — local agent scratch, not source) ---
/.ralph/

# --- sb-player web client ---
/sb-player/node_modules/
/sb-player/dist/
/sb-player/*.log
/sb-player/*.png

# --- Beads issue tracker ---
# Runtime data is ignored via .beads/.gitignore; config/metadata are tracked.
.dolt/
*.db
.beads-credential-key
.beads/interactions.jsonl
